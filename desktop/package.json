{
  "name": "emperor-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Emperor Agent desktop application (Electron + Vue) that hosts CoreApi in process.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "screenshots": "playwright test -c playwright.config.ts",
    "typecheck:test": "tsc --noEmit -p tsconfig.test-web.json && tsc --noEmit -p tsconfig.test-node.json",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "package:dir": "electron-builder --dir --publish never",
    "package:smoke": "node scripts/run-packaged-smoke.cjs",
    "package:verify": "npm run package:dir && npm run package:smoke",
    "dist:mac": "cd .. && scripts/build_desktop_release.sh",
    "dist:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist": "npm run dist:mac"
  },
  "dependencies": {},
  "devDependencies": {
    "@emperor/core": "file:../packages/core",
    "@electron/asar": "^3.4.1",
    "@playwright/test": "^1.61.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-vue-next": "^0.577.0",
    "markdown-it": "^14.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^9.4.3",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue-tsc": "^2.2.0"
  }
}
