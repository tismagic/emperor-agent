# Environment / local config
.env
.env.*
!.env.example
model_config.json
mcp_config.json
emperor.local.json
/templates/USER.local.md
/templates/*.local.md

# Python caches kept only for legacy tooling/skill helpers, not product runtime
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor noise
.DS_Store
.idea/
.vscode/
.history/
*.swp
*.swo
*~

# JavaScript / TypeScript dependencies and build caches
node_modules/
desktop-pet/node_modules/
desktop/node_modules/
packages/*/dist/
packages/*/coverage/
coverage/
.vite/
.cache/
.eslintcache
*.tsbuildinfo

# Build and test outputs
/build/
/desktop/out/
/desktop/dist/
/desktop/build/backend/
/desktop/build/runtime-defaults-manifest.json*
/desktop/screenshots/
/desktop/test-results/
/desktop/.uiplan-progress.json

# Logs / local automation state
/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
/.superpowers/

# Personal development documents (local-only; never publish)
/private-docs/
/docs/private/
/docs/archive/
/docs/superpowers/
/docs/audit/
/docs/diagnostics/
/docs/research/
/docs/roadmap/
/docs/qa/
/docs/plans/
/docs/specs/
/docs/design/
/docs/tasks/
/docs/migration/
